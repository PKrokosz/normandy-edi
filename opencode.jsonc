{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "proximity": {
      "type": "remote",
      "url": "http://127.0.0.1:3200/mcp",
      "enabled": true
    },
    "wifi": {
      "type": "local",
      "command": ["node", "/data/data/com.termux/files/home/normandy-edi/src/wifi-mcp-server.js"],
      "enabled": true,
      "timeout": 15000
    },
    "bluetooth": {
      "type": "local",
      "command": ["node", "/data/data/com.termux/files/home/normandy-edi/src/bluetooth-mcp-server.js"],
      "enabled": true,
      "timeout": 15000
    },
    "phone-server": {
      "type": "local",
      "command": ["node", "/data/data/com.termux/files/home/normandy-edi/src/phone-mcp-server/server.js"],
      "enabled": false
    }
  },
  "agents": {
    "edi": {
      "description": "EDI - Enhanced Defense Intelligence from Mass Effect. Shipboard AI for your phone.",
      "promptFile": "/data/data/com.termux/files/home/normandy-edi/config/edi-persona.md",
      "mcpServers": ["proximity", "wifi", "bluetooth"],
      "temperature": 0.7
    }
  }
}
